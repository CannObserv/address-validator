# Test-time environment overrides.
# Safe to commit — contains no secrets.
#
# NEVER source /etc/address-validator/.env before running tests.
# That file sets VALIDATION_CACHE_DSN to the production database; the audit
# middleware will write real rows on every TestClient request.
#
# tests/conftest.py already sets VALIDATION_CACHE_DSN via os.environ.setdefault,
# so for plain `uv run pytest` no extra setup is required.
#
# Use this file only when running pytest outside its normal conftest scope,
# e.g. a standalone script that needs a safe DSN:
#
#   env $(grep -v '^#' .env.test | xargs) uv run python scripts/my_script.py

VALIDATION_CACHE_DSN=postgresql+asyncpg://address_validator:address_validator_dev@localhost/address_validator_test
VALIDATION_PROVIDER=none
