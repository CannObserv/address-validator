[Unit]
Description=Remove Docker build cache, stopped containers, dangling images, unused networks
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
User=exedev
ExecStart=/usr/bin/docker system prune -f
ExecStartPost=/home/exedev/address-validator/scripts/docker-prune-check.sh

[Install]
WantedBy=multi-user.target
